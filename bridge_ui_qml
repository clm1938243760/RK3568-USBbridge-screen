#!/bin/sh

BASE=/root/usb_bridge
QML_FILE=${BRIDGE_UI_QML:-$BASE/ui/usb_bridge_ui.qml}
LOG=$BASE/logs/bridge_ui_qml.log

mkdir -p "$BASE/logs"

FB="${BRIDGE_UI_FB_DEV:-/dev/fb0}"
PLATFORM="${BRIDGE_UI_QML_PLATFORM:-${QT_QPA_PLATFORM:-auto}}"

if [ "$PLATFORM" = "auto" ]; then
    if [ -n "$WAYLAND_DISPLAY" ]; then
        PLATFORM=wayland
    elif [ -n "$DISPLAY" ]; then
        PLATFORM=xcb
    elif [ -e "$FB" ]; then
        PLATFORM=linuxfb
    else
        PLATFORM=minimal
    fi
fi

case "$PLATFORM" in
    wayland*)
        I=0
        while [ "$I" -lt "${BRIDGE_UI_WAYLAND_WAIT:-30}" ]; do
            WAYLAND_SOCK=""
            for DIR in "${XDG_RUNTIME_DIR:-}" /run/user/0 /run /var/run; do
                [ -n "$DIR" ] || continue
                [ -d "$DIR" ] || continue
                for SOCK in "$DIR"/wayland-*; do
                    if [ -S "$SOCK" ]; then
                        WAYLAND_SOCK="$SOCK"
                        break
                    fi
                done
                [ -n "$WAYLAND_SOCK" ] && break
            done

            if [ -S "$WAYLAND_SOCK" ]; then
                break
            fi
            if [ "$I" -eq 0 ] && [ -x /etc/init.d/S49weston ] && ! pgrep -f weston >/dev/null 2>&1; then
                echo "[$(date '+%F %T')] starting weston for wayland display" >> "$LOG"
                /etc/init.d/S49weston start >> "$LOG" 2>&1 || true
            fi
            echo "[$(date '+%F %T')] waiting for wayland socket" >> "$LOG"
            I=$((I + 1))
            sleep 1
        done

        if [ ! -S "$WAYLAND_SOCK" ]; then
            echo "[$(date '+%F %T')] ERROR wayland socket not ready" >> "$LOG"
            exit 1
        fi

        export XDG_RUNTIME_DIR="$(dirname "$WAYLAND_SOCK")"
        export WAYLAND_DISPLAY="$(basename "$WAYLAND_SOCK")"
        echo "[$(date '+%F %T')] wayland ready: XDG_RUNTIME_DIR=$XDG_RUNTIME_DIR WAYLAND_DISPLAY=$WAYLAND_DISPLAY" >> "$LOG"
        export QT_WAYLAND_DISABLE_WINDOWDECORATION="${QT_WAYLAND_DISABLE_WINDOWDECORATION:-1}"
        export QT_QUICK_BACKEND="${QT_QUICK_BACKEND:-software}"
        export QML_XHR_ALLOW_FILE_READ="${QML_XHR_ALLOW_FILE_READ:-1}"
        ;;
    linuxfb*)
        I=0
        while [ "$I" -lt "${BRIDGE_UI_FB_WAIT:-20}" ]; do
            [ -e "$FB" ] && break
            echo "[$(date '+%F %T')] waiting for framebuffer: $FB" >> "$LOG"
            I=$((I + 1))
            sleep 1
        done
        export QT_QUICK_BACKEND="${QT_QUICK_BACKEND:-software}"
        export QT_OPENGL="${QT_OPENGL:-software}"
        export QT_QPA_FB_FORCE_FULLSCREEN="${QT_QPA_FB_FORCE_FULLSCREEN:-1}"
        ;;
esac

export QT_QPA_PLATFORM="$PLATFORM"
export QML2_IMPORT_PATH="${QML2_IMPORT_PATH:-/usr/lib/qt/qml:/usr/qml}"

cd "$(dirname "$QML_FILE")" || exit 1

if command -v qmlscene >/dev/null 2>&1; then
    echo "[$(date '+%F %T')] start qmlscene platform=$PLATFORM file=$QML_FILE" >> "$LOG"
    exec qmlscene -platform "$QT_QPA_PLATFORM" "$QML_FILE" >> "$LOG" 2>&1
fi

if command -v qml >/dev/null 2>&1; then
    echo "[$(date '+%F %T')] start qml platform=$PLATFORM file=$QML_FILE" >> "$LOG"
    exec qml -platform "$QT_QPA_PLATFORM" "$QML_FILE" >> "$LOG" 2>&1
fi

echo "No qmlscene/qml command found" >> "$LOG"
exit 127
